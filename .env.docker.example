# URL publica final del sitio detras del reverse proxy de Synology
NEXTAUTH_URL=https://tu-dominio.com

# Genera un secreto largo y aleatorio
NEXTAUTH_SECRET=cambia-esto-por-un-secreto-largo-y-seguro

# Recomendado detras de proxy
AUTH_TRUST_HOST=true

# Solo se usan en el PRIMER arranque si la tabla users esta vacia
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esto-por-una-password-inicial-segura

# Opcional, recomendable si algun dia corres mas de una instancia
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Opcional
TZ=Europe/Madrid
